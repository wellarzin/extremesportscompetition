# ============================================================
# Extreme Competition API — Variáveis de Ambiente
# Copie este arquivo para .env e preencha todos os valores
# ============================================================

# ---- NeonDB (PostgreSQL) ----
DATABASE_URL="postgresql://USER:PASSWORD@ep-XXXX.us-east-2.aws.neon.tech/neondb?sslmode=require&pgbouncer=true&connect_timeout=15"
DIRECT_URL="postgresql://USER:PASSWORD@ep-XXXX.us-east-2.aws.neon.tech/neondb?sslmode=require"

# ---- JWT RS256 — par de chaves assimétricas ----
# Gere com: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
# Cole o conteúdo do PEM aqui em uma linha, substituindo quebras por \n
# Exemplo: "-----BEGIN RSA PRIVATE KEY-----\nMIIEo...\n-----END RSA PRIVATE KEY-----"
JWT_PRIVATE_KEY=JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n\n-----END PRIVATE KEY-----\n"
JWT_PUBLIC_KEY=JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n\n-----END PUBLIC KEY-----\n"

# ---- AES-256-GCM — criptografia de documentos ----
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AES_SECRET_KEY="asdasdasd"

# ---- HMAC — hash determinístico para unicidade de documentos ----
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
HMAC_SECRET_KEY="asdasdasdasd"

# ---- Redis — rate limiting distribuído (opcional em dev) ----
# Recomendado: Upstash Redis (free tier serverless)
REDIS_URL="redis://default:SENHA@HOST:PORT"

# ---- Servidor ----
PORT=3333
HOST="0.0.0.0"
NODE_ENV="development"

# ---- CORS ----
ALLOWED_ORIGINS="http://localhost:5173,http://localhost:3000"

# ---- Swagger (Basic Auth obrigatório em produção) ----
SWAGGER_USER="admin"
SWAGGER_PASS="troque_em_producao"

# ---- App URL (para links nos e-mails) ----
APP_URL="http://localhost:5173"
